# PM Tool MCP Server Configuration (.env.example)

# API Backend Connection
PMTOOL_API_BASE_URL=
PMTOOL_API_TOKEN=

# MCP Server Settings
# Port for the Streamable HTTP transport to listen on (Render uses PORT dynamically)
PORT=8001
MCP_HOST=0.0.0.0

# Transport protocol to use ("sse" recommended for remote Hey Tam deployment)
MCP_TRANSPORT=sse

# Authentication Provider ("oauth2" for production, "none" for local testing without OAuth)
MCP_AUTH_PROVIDER=oauth2

# OAuth 2.1 PKCE Settings
# Configuration for the FastMCP OAuth provider to support per-request context
OAUTH_CLIENT_ID=
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=